{
  "name": "@libreoj/bootstrap-config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./config.json": "./config.json"
  },
  "scripts": {
    "build": "tsx src/build.ts",
    "check-format": "prettier --check \"src/**/*.ts\" package.json settings.json tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" package.json settings.json tsconfig.json"
  },
  "dependencies": {
    "@libreoj/frontend": "workspace:*",
    "@libreoj/service-worker": "workspace:*",
    "cheerio": "1.0.0-rc.10",
    "git-repo-info": "^2.1.1",
    "terser": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "18.6.3",
    "prettier": "catalog:",
    "tsx": "4.23.1",
    "typescript": "^4.7.4"
  }
}
